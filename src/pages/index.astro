---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Services from '@components/Services.astro';
import AboutCompany from '@components/AboutCompany.astro';
import CTA from '@components/CTA.astro';
---

<BaseLayout
  title="Full Estratégias Digitais | SEO Local e Marketing Digital em Brasília, DF"
  description="Agência de marketing digital especializada em SEO local, geração de leads e estratégias digitais orientadas por dados. Brasília, DF."
>
  {/* 1. Hero Section */}
  <Hero
    title="Estratégias digitais que geram resultados"
    subtitle="Conectamos empresas locais de Brasília aos clientes que já estão buscando por elas no Google. SEO local, geração de leads e marketing orientado por dados."
    ctaText="Fale Conosco no WhatsApp"
    ctaUrl="https://wa.me/5561974022227?text=Ol%C3%A1%2C%20gostaria%20de%20saber%20mais%20sobre%20os%20servi%C3%A7os%20da%20Full%20ED"
    isDark={true}
  />

  {/* 2. Serviços */}
  <Services />

  {/* 3. Sobre a Empresa */}
  <AboutCompany />

  {/* 4. CTA Final */}
  <section id="contato">
    <CTA
      title="Vamos conversar sobre o seu negócio"
      description="Agende uma conversa gratuita com nossa equipe. Vamos analisar a presença digital do seu negócio e apresentar um plano estratégico personalizado."
      primaryText="Falar no WhatsApp"
      primaryUrl="https://wa.me/5561974022227?text=Ol%C3%A1%2C%20gostaria%20de%20saber%20mais%20sobre%20os%20servi%C3%A7os%20da%20Full%20ED"
      secondaryText="Enviar E-mail"
      secondaryUrl="mailto:contato@fulled.com.br"
    />
  </section>
</BaseLayout>
