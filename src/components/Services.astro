---
import { services } from '../data/services';

const servicesSchema = services.map((service) => ({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": service.name,
  "description": service.description,
  "provider": {
    "@type": "ProfessionalService",
    "name": "Full Estratégias Digitais",
    "url": "https://fulled.com.br",
    "areaServed": "Brasília, DF"
  },
  "serviceType": "Marketing Digital"
}));
---

<!-- Service Schema JSON-LD -->
{servicesSchema.map((schema) => (
  <>
    <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
  </>
))}

<section class="py-12 md:py-20 lg:py-24 bg-gradient-to-b from-white to-surface-alt" id="servicos">
  <div class="container mx-auto px-4 md:px-6">
    <div class="text-center mb-12 md:mb-16">
      <span class="inline-block px-4 py-2 rounded-full text-sm font-semibold mb-4 bg-blue-100 text-secondary">
        Soluções Completas
      </span>
      <h2 class="text-3xl sm:text-4xl md:text-4xl font-bold text-gray-900 mb-4">
        Serviços Full Estratégias Digitais
      </h2>
      <p class="text-base md:text-lg text-gray-600 max-w-2xl mx-auto">
        Estratégias digitais orientadas por dados para conectar o seu negócio aos clientes certos no momento certo.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {services.map((service, index) => {
        const isHighlighted = index < 2;

        return (
          <div class={`
            relative bg-white rounded-xl transition-all duration-300 overflow-hidden group
            ${isHighlighted ? 'border-2 border-secondary shadow-xl hover:shadow-2xl hover:scale-105' : 'border border-gray-200 shadow-md hover:shadow-lg hover:scale-105'}
          `}>
            <div class="p-6 md:p-8">
              <div class={`w-14 h-14 rounded-xl flex items-center justify-center mb-6 transition-all duration-300 group-hover:scale-110 ${isHighlighted ? 'bg-secondary text-white' : 'bg-blue-100 text-secondary'}`}>
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={service.icon} />
                </svg>
              </div>

              <h3 class="text-lg md:text-xl font-bold mb-3 text-gray-900">
                {service.name}
              </h3>

              <p class="text-gray-600 text-sm md:text-base leading-relaxed mb-6">
                {service.description}
              </p>

              <ul class="space-y-2 mb-6">
                {service.features.map((feature) => (
                  <li class="flex items-start gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        );
      })}
    </div>

    <div class="text-center mt-12 md:mt-16">
      <a
        href="https://wa.me/5561974022227?text=Ol%C3%A1%2C%20gostaria%20de%20saber%20mais%20sobre%20os%20servi%C3%A7os%20da%20Full%20ED"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center px-8 py-4 bg-secondary hover:bg-secondary-dark text-white font-bold text-base md:text-lg rounded-lg hover:shadow-lg transition-all duration-300 active:scale-95 hover:scale-105"
      >
        Fale com um Especialista →
      </a>
    </div>
  </div>
</section>
