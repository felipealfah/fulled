---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contato | Full Estratégias Digitais — Brasília, DF"
  description="Entre em contato com a Full Estratégias Digitais. Agende uma conversa gratuita sobre SEO local, geração de leads e estratégias digitais para o seu negócio."
>
  {/* Hero */}
  <section class="py-20 md:py-32 bg-gradient-to-br from-indigo-600 to-violet-700 text-white">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
        Fale Conosco
      </h1>
      <p class="text-xl md:text-2xl text-indigo-100 max-w-3xl mx-auto">
        Vamos conversar sobre o seu negócio e como podemos gerar mais resultados digitais para você.
      </p>
    </div>
  </section>

  {/* Contact Info + Form */}
  <section class="py-12 md:py-20 bg-gray-50">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {/* Email */}
        <div class="bg-white p-8 rounded-lg shadow-md text-center hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 bg-indigo-100 rounded-lg flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-3">Email</h3>
          <a href="mailto:contato@fulled.com.br" class="text-primary font-semibold hover:text-primary-dark transition-colors">
            contato@fulled.com.br
          </a>
        </div>

        {/* Location */}
        <div class="bg-white p-8 rounded-lg shadow-md text-center hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 bg-indigo-100 rounded-lg flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-3">Localização</h3>
          <p class="text-gray-600">Brasília, DF — Brasil</p>
        </div>

        {/* Hours */}
        <div class="bg-white p-8 rounded-lg shadow-md text-center hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 bg-indigo-100 rounded-lg flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-3">Horário</h3>
          <p class="text-gray-600">Seg–Sex, 09h–18h</p>
        </div>
      </div>

      {/* Contact Form */}
      <div class="bg-white p-8 md:p-12 rounded-xl shadow-md">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-2 text-center">Envie sua mensagem</h2>
        <p class="text-gray-600 text-center mb-8">Responderemos em até 1 dia útil.</p>

        <form class="space-y-6" action={`mailto:contato@fulled.com.br`} method="get">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-semibold text-gray-900 mb-2">Nome *</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition"
                placeholder="Seu nome"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold text-gray-900 mb-2">Email *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition"
                placeholder="seu@email.com"
              />
            </div>
          </div>

          <div>
            <label for="empresa" class="block text-sm font-semibold text-gray-900 mb-2">Empresa</label>
            <input
              type="text"
              id="empresa"
              name="empresa"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition"
              placeholder="Nome da sua empresa"
            />
          </div>

          <div>
            <label for="servico" class="block text-sm font-semibold text-gray-900 mb-2">Serviço de interesse</label>
            <select
              id="servico"
              name="servico"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition"
            >
              <option value="">Selecione um serviço</option>
              <option value="seo-local">SEO Local</option>
              <option value="geracao-leads">Geração de Leads</option>
              <option value="analise-dados">Análise de Dados</option>
              <option value="marketing-conteudo">Marketing de Conteúdo</option>
              <option value="desenvolvimento-web">Desenvolvimento Web</option>
              <option value="consultoria-digital">Consultoria Digital</option>
            </select>
          </div>

          <div>
            <label for="mensagem" class="block text-sm font-semibold text-gray-900 mb-2">Mensagem *</label>
            <textarea
              id="mensagem"
              name="mensagem"
              rows="5"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition"
              placeholder="Conte um pouco sobre o seu negócio e o que você precisa..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full px-8 py-4 bg-primary text-white font-bold rounded-lg hover:bg-primary-dark transition-colors shadow-lg hover:shadow-xl active:scale-95"
          >
            Enviar Mensagem →
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
