---
import '@styles/global.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Full Estratégias Digitais" />
    <meta name="theme-color" content="#04020f" />

    <title>{title}</title>
    <link rel="canonical" href={Astro.url} />

    {/* Open Graph Tags - Compartilhamento Social */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:site_name" content="Full Estratégias Digitais" />

    {/* Twitter Card Tags */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />


    {/* Prefetch de rotas importantes (DNS only, sem CSS) */}
    <link rel="dns-prefetch" href="/" />
    <link rel="dns-prefetch" href="#sobre" />
    <link rel="dns-prefetch" href="#servicos" />
    <link rel="dns-prefetch" href="#contato" />

    {/* Structured Data - Organization */}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Full Estratégias Digitais",
      "url": "https://fulled.com.br",
      "description": "Agência de marketing digital especializada em SEO local, geração de leads e estratégias digitais orientadas por dados.",
      "telephone": "+55-61-97402-2227",
      "email": "contato@fulled.com.br",
      "sameAs": [
        "https://www.instagram.com/fulled.com.br"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "Customer Service",
        "telephone": "+55-61-97402-2227",
        "email": "contato@fulled.com.br"
      },
      "areaServed": {
        "@type": "Place",
        "name": "Brasília, DF — Brasil"
      }
    })}></script>

    {/* Structured Data - WebSite */}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Full Estratégias Digitais",
      "url": "https://fulled.com.br"
    })}></script>

    {/* Structured Data - LocalBusiness */}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Full Estratégias Digitais",
      "description": "Agência de marketing digital especializada em SEO local, geração de leads e estratégias digitais orientadas por dados.",
      "url": "https://fulled.com.br",
      "telephone": "+55-61-97402-2227",
      "email": "contato@fulled.com.br",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Brasília",
        "addressRegion": "DF",
        "addressCountry": "BR"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "09:00",
        "closes": "18:00"
      }
    })}></script>
  </head>
  <body>
    <Header />
    <main class="min-h-screen">
      <slot />
    </main>
    <Footer />
  </body>
</html>
